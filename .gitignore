# =============================================================================
# Java / Maven
# =============================================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

hs_err_pid*
replay_pid*

# =============================================================================
# Maven wrapper (keep mvnw script, ignore local binary cache)
# =============================================================================
.mvn/wrapper/maven-wrapper.properties
!.mvn/wrapper/maven-wrapper.properties

# =============================================================================
