# =============================================================================
# AuraDev ERP API — environment variables (copy to .env for local dev)
# =============================================================================

# --- Production (Railway / Render) ---------------------------------------------
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://your-pooler-host:6543/postgres?sslmode=require
DB_USERNAME=your-pooler-user
DB_PASSWORD=your-database-password

JWT_SECRET=replace-with-a-long-random-base64-string

# Frontend origin(s), comma-separated, no trailing slash
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example

# Public API URL for logo/upload links in settings — no trailing slash
APP_PUBLIC_BASE_URL=https://your-api-domain.example

APP_UPLOADS_DIR=/var/data/uploads

# --- Local dev ----------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=dev
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
# DB_USERNAME=postgres
# DB_PASSWORD=...
# JWT_SECRET=...
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# APP_PUBLIC_BASE_URL=http://localhost:8080
