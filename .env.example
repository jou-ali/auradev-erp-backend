# ─────────────────────────────────────────────────
# AuraDev ERP — Environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────

# Spring profile  (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Server
PORT=8080

# ── Database (Supabase Postgres) ──────────────────
# Use session mode (port 5432) NOT transaction mode (6543)
# to avoid prepared-statement issues with HikariCP.
DB_URL=postgresql://postgres.vbtculgklmtfujwugglf:AuradevErp@123@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
DB_USERNAME=postgres.vbtculgklmtfujwugglf
DB_PASSWORD=AuradevErp@123

# ── Redis (Upstash) ───────────────────────────────
REDIS_URL=rediss://:<password>@<endpoint>.upstash.io:6379

# ── JWT ───────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-base64-string

# ── CORS ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Supabase Storage (S3-compatible) ─────────────
SUPABASE_STORAGE_URL=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_STORAGE_KEY=your-supabase-anon-or-service-key
SUPABASE_STORAGE_SECRET=your-supabase-storage-secret

# ── Optional: Sentry error tracking ──────────────
# SENTRY_DSN=https://...@sentry.io/...
